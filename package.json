{
  "name": "context8",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "context8": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
