    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tsconfig/node24": "^24.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
